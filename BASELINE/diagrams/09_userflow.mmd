flowchart TD
  Start[Landing] --> Reg[Register account_type]
  Reg --> Login[Login]
  Login --> Pricing[Package Offer]
  Pricing --> Trial[Start Trial]
  Pricing --> Pay[Checkout PaymentGateway]
